<Window x:Class="Orientir.Desktop.AdvancedSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додаткові налаштування" Height="580" Width="640"
        Icon="app.ico"
        WindowStartupLocation="CenterOwner" FontSize="13">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Прапорці -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <CheckBox x:Name="ChkPoints" Content="Рахувати бали" Margin="0,4"
                      Checked="Flag_Changed" Unchecked="Flag_Changed" />
            <CheckBox x:Name="ChkSum" Content="Рахувати суму (залік за всі дні)" Margin="20,4,0,4" />
            <TextBlock Text="Об'єднувати «Результат» і «Статус/DSQ» в одну колонку:" Margin="0,8,0,2" Foreground="#444" />
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <!-- Увага: «розділяти» = окрема колонка DSQ. Знятий прапорець = об'єднано. -->
                <CheckBox x:Name="ChkSeparateDsqLg" Content="Розділяти на великому екрані" Margin="0,0,24,0"
                          Checked="Flag_Changed" Unchecked="Flag_Changed" />
                <CheckBox x:Name="ChkSeparateDsqSm" Content="Розділяти на малому екрані"
                          Checked="Flag_Changed" Unchecked="Flag_Changed" />
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,4,0,6" Foreground="Gray"
                   Text="Колонки таблиці результатів. Оберіть, які показувати на великому й малому екрані. Порядок змінюйте перетягуванням рядка — синя лінія показує, куди він стане." />

        <!-- Колонки. Шаблонні чекбокси: реагують на ОДИН клік і можуть бути disabled. -->
        <DataGrid Grid.Row="2" x:Name="GridColumns" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserReorderColumns="False" SelectionMode="Single"
                  HeadersVisibility="Column"
                  PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown"
                  MouseMove="Grid_MouseMove" Drop="Grid_Drop" AllowDrop="True"
                  DragOver="Grid_DragOver" DragLeave="Grid_DragLeave"
                  QueryContinueDrag="Grid_QueryContinueDrag">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Колонка" Binding="{Binding Title}" Width="*" IsReadOnly="True" />
                <DataGridTemplateColumn Header="Великий екран" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      IsChecked="{Binding Lg, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding LgEnabled}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Малий екран" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      IsChecked="{Binding Sm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding SmEnabled}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Використовувати поточний вигляд за замовчуванням" Padding="12,4"
                    Click="UseAsDefault_Click"
                    ToolTip="Зберегти поточні колонки й прапорці як типовий вигляд для нових змагань" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK"        Width="90" Margin="20,0,8,0" IsDefault="True" Click="Ok_Click" />
                <Button Content="Скасувати" Width="90" IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
