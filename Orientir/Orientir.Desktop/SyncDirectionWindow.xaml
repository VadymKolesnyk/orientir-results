<Window x:Class="Orientir.Desktop.SyncDirectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Синхронізація налаштувань" Height="220" Width="440"
        Icon="app.ico" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtPrompt" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="Оберіть напрямок синхронізації налаштувань." />

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Button Content="⬆  Локально → Сервер  (вивантажити мої налаштування)"
                    Height="40" Margin="0,0,0,8" Click="ToServer_Click" />
            <Button Content="⬇  Сервер → Локально  (завантажити з сервера)"
                    Height="40" Click="ToLocal_Click" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Скасувати" Width="100" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
