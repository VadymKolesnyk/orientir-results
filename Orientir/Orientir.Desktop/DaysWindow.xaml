<Window x:Class="Orientir.Desktop.DaysWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Дні змагання" Height="440" Width="580"
        Icon="app.ico"
        WindowStartupLocation="CenterOwner" FontSize="13">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8" Foreground="Gray"
                   Text="Дні D_1..D_n знаходяться автоматично (D_0 пропускається). Введіть лише підпис для кожного дня." />

        <Button Grid.Row="1" Content="🔄 Сканувати теку повторно" HorizontalAlignment="Left"
                Width="220" Margin="0,0,0,8" Click="Rescan_Click" />

        <DataGrid Grid.Row="2" x:Name="GridDays" AutoGenerateColumns="False" CanUserAddRows="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="День"   Binding="{Binding Day}"    Width="70" />
                <DataGridTextColumn Header="Тека"   Binding="{Binding Folder}" Width="150" />
                <DataGridTextColumn Header="Підпис" Binding="{Binding Label}"  Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Видалити рядок" Width="120" Margin="0,0,8,0" Click="DeleteRow_Click" />
            <Button Content="OK"     Width="90" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click" />
            <Button Content="Скасувати" Width="90" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
